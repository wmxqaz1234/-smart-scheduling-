{
  "_comment": "智能排班系统配置 - 请运行 install.py 或 init_config.py 自动生成",
  "app_id": "YOUR_APP_ID",
  "api_key": "YOUR_API_KEY",
  "tables": {
    "employee": {
      "entry_id": "YOUR_EMPLOYEE_ENTRY_ID",
      "fields": {
        "name": "",
        "employee_id": "",
        "department": "",
        "position": "",
        "skill_level": "",
        "max_weekly_days": "",
        "status": ""
      }
    },
    "shift_template": {
      "entry_id": "YOUR_SHIFT_TEMPLATE_ENTRY_ID",
      "fields": {
        "name": "",
        "start_time": "",
        "end_time": "",
        "duration_hours": "",
        "required_count": "",
        "shift_type": "",
        "required_skill": ""
      }
    },
    "schedule_rule": {
      "entry_id": "YOUR_SCHEDULE_RULE_ENTRY_ID",
      "fields": {
        "name": "",
        "rule_type": "",
        "param_value": "",
        "priority": "",
        "enabled": ""
      }
    },
    "schedule": {
      "entry_id": "YOUR_SCHEDULE_ENTRY_ID",
      "fields": {
        "period": "",
        "employee": "",
        "date": "",
        "shift": "",
        "shift_name": "",
        "status": "",
        "employee_id": "",
        "remark": ""
      }
    },
    "leave": {
      "entry_id": "YOUR_LEAVE_ENTRY_ID",
      "fields": {
        "employee_id": "",
        "applicant": "",
        "leave_type": "",
        "start_date": "",
        "end_date": "",
        "reason": "",
        "approval_status": "",
        "candidates_subform": "",
        "sub_datetime": "",
        "sub_shift": "",
        "sub_employee_id": "",
        "sub_name": "",
        "shift_name": "",
        "required_skill": ""
      }
    }
  },
  "webhook_payload_fields": {
    "employee_id": "",
    "applicant": "",
    "leave_date": ""
  }
}
